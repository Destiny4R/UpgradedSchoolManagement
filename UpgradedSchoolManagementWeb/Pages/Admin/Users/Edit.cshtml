@page
@model UpgradedSchoolManagementWeb.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Edit User";
}
@section Sheets {
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<div class="mgmt-page">

    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-person-gear me-2" style="color:var(--accent)"></i>Edit User</div>
            <div class="mgmt-sub">Update user information</div>
        </div>
        <a class="btn-secondary btn-sm btn" href="/Admin/Users">
            <i class="bi bi-arrow-left"></i> Back to Users
        </a>
    </div>

    <div class="mgmt-card fade-in">
        <div class="mgmt-card-body">
            <form id="userForm">
                <input type="hidden" id="userId" value="@Model.Id" />
                <div class="mb-3">
                    <label for="fullName" class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="fullName" value="@Model.FullName" required />
                </div>
                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" @(Model.IsActive ? "checked" : "")>
                        <label class="form-check-label" for="isActive">Active Account</label>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Update User
                    </button>
                    <a class="btn btn-secondary" href="/Admin/Users">Cancel</a>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/lib/jquery.blockUI/jquery.blockUI.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script>
        $('#userForm').on('submit', function (e) {
            e.preventDefault();
            var fullName = $('#fullName').val().trim();
            if (!fullName) { Swal.fire('Validation', 'Full name is required', 'warning'); return; }

            unBlockUlloader();
            $.ajax({
                url: '/V1/UpdateUser',
                type: 'POST',
                data: JSON.stringify({
                    Id: $('#userId').val(),
                    FullName: fullName,
                    IsActive: $('#isActive').is(':checked')
                }),
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    if (r.success) {
                        Swal.fire('Success', r.message, 'success').then(function () {
                            window.location.href = '/Admin/Users';
                        });
                    } else {
                        Swal.fire('Error', r.message, 'error');
                    }
                },
                complete: function () { $.unblockUI(); },
                error: function () { Swal.fire('Error', 'An error occurred.', 'error'); }
            });
        });

        function unBlockUlloader(){
            $.blockUI({
                message: '<div class="bs-spinner mt-4 mt-lg-0"><div class= "spinner-border text-success mr-2 mt-2" style="width: 10rem; height: 10rem;" role="status"><span class="sr-only">Loading...</span></div> ',
                fadeIn: 800,
                //timeout: 2000, unblock after 2 seconds
                overlayCSS: {
                    backgroundColor: '#1b2024',
                    opacity: 0.8,
                    zIndex: 1200,
                    cursor: 'wait'
                },
                css: {
                    border: 0,
                    color: '#fff',
                    zIndex: 1201,
                    padding: 0,
                    backgroundColor: 'transparent'
                },
                onBlock: function () {

                }
            });
        }
    </script>
}
