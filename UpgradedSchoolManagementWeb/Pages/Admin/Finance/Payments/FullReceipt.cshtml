@page
@model UpgradedSchoolManagementWeb.Pages.Admin.Finance.Payments.FullReceiptModel
@{
    ViewData["Title"] = "Full Term Receipt";
}

<style>
    @@media print {
        .no-print { display: none !important; }
        .receipt-page { box-shadow: none !important; margin: 0 !important; padding: 0 !important; }
        .receipt-body { padding: 20px !important; }
        @@page { margin: 15mm; }
    }

    .receipt-page {
        max-width: 900px;
        margin: 0 auto;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--card-shadow);
    }

    .receipt-header {
        text-align: center;
        padding: 30px 30px 20px;
        border-bottom: 2px dashed var(--border);
    }

    .receipt-header .school-name {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -.3px;
    }

    .receipt-header .receipt-title {
        font-size: 16px;
        font-weight: 600;
        color: var(--accent);
        margin-top: 6px;
    }

    .receipt-header .receipt-meta {
        font-size: 13px;
        color: var(--muted);
        margin-top: 4px;
    }

    .receipt-body {
        padding: 24px 30px;
    }

    .receipt-section {
        margin-bottom: 20px;
    }

    .receipt-section h6 {
        font-size: 13px;
        font-weight: 600;
        color: var(--accent2);
        border-bottom: 1px solid var(--border);
        padding-bottom: 6px;
        margin-bottom: 10px;
    }

    .receipt-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .receipt-table th,
    .receipt-table td {
        padding: 6px 8px;
        border-bottom: 1px solid var(--border);
    }

    .receipt-table th {
        font-weight: 600;
        color: var(--muted);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .receipt-table tfoot td {
        font-weight: 700;
        border-bottom: none;
        border-top: 2px solid var(--border);
    }

    .summary-card {
        background: var(--surface2);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
    }

    .summary-card .value {
        font-size: 20px;
        font-weight: 700;
    }

    .summary-card .label {
        font-size: 12px;
        color: var(--muted);
    }

    .receipt-print-btn {
        text-align: center;
        padding: 20px 30px;
    }
</style>

<div class="mgmt-page no-print">
    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-receipt me-2" style="color:var(--accent)"></i>Full Term Receipt</div>
            <div class="mgmt-sub">Consolidated term payment receipt</div>
        </div>
        <a asp-page="/Admin/Finance/Payments/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Payments
        </a>
    </div>
</div>

<div class="mgmt-page" style="padding-top:0">
    <div class="receipt-page fade-in">
        <div class="receipt-header">
            <div class="school-name"><i class="bi bi-mortarboard-fill me-2" style="color:var(--accent)"></i><span id="schoolName">School Name</span></div>
            <div class="receipt-title">&#9749; TERM PAYMENT RECEIPT</div>
            <div class="receipt-meta" id="termMeta">
                <span id="sessionTermLabel">--</span>
                &nbsp;&middot;&nbsp;
                Generated: <span class="fw-semibold" id="generatedDate">--</span>
            </div>
        </div>

        <div class="receipt-body">
            <div class="receipt-section">
                <h6>Student Information</h6>
                <div class="row g-2">
                    <div class="col-sm-6"><strong>Name:</strong> <span id="studentName">--</span></div>
                    <div class="col-sm-6"><strong>Admission No:</strong> <span id="admissionNo">--</span></div>
                    <div class="col-sm-6"><strong>Class:</strong> <span id="className">--</span></div>
                    <div class="col-sm-6"><strong>Arm:</strong> <span id="arm">--</span></div>
                </div>
            </div>

            <div class="receipt-section">
                <h6>Payment Summary</h6>
                <div class="row g-3 mb-3">
                    <div class="col-sm-4">
                        <div class="summary-card">
                            <div class="value" style="color:var(--accent)" id="totalExpected">0.00</div>
                            <div class="label">Total Expected</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="summary-card">
                            <div class="value" style="color:var(--accent3)" id="totalPaid">0.00</div>
                            <div class="label">Total Paid</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="summary-card">
                            <div class="value" style="color:var(--accent4)" id="outstanding">0.00</div>
                            <div class="label">Outstanding Balance</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="receipt-section">
                <h6>Fee Item Breakdown</h6>
                <table class="receipt-table">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Item</th>
                            <th class="text-end">Expected</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Balance</th>
                        </tr>
                    </thead>
                    <tbody id="breakdownBody"></tbody>
                    <tfoot>
                        <tr>
                            <td colspan="2" class="text-end fw-bold">Totals</td>
                            <td class="text-end fw-bold" id="totalExpectedFoot">0.00</td>
                            <td class="text-end fw-bold" id="totalPaidFoot">0.00</td>
                            <td class="text-end fw-bold" id="totalBalanceFoot">0.00</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="receipt-section">
                <h6>Payment History</h6>
                <table class="receipt-table">
                    <thead>
                        <tr>
                            <th>S/N</th>
                            <th>Reference</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="historyBody"></tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total Paid</td>
                            <td class="text-end fw-bold" id="historyTotal">0.00</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="receipt-print-btn no-print">
            <button class="btn-mgmt-primary" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> Print Receipt
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const params = new URLSearchParams(window.location.search);
        const admissionNo = params.get('admissionNo');
        const termRegistrationId = params.get('termRegistrationId');

        if (!admissionNo || !termRegistrationId) {
            Swal.fire('Error', 'Missing admissionNo or termRegistrationId parameters.', 'error').then(function () {
                window.location.href = '/Admin/Finance/Payments/Index';
            });
        }

        function loadFullReceipt() {
            $.ajax({
                url: '/V1/GetFullTermReceipt',
                type: 'POST',
                data: JSON.stringify({
                    AdmissionNo: admissionNo,
                    TermRegistrationId: parseInt(termRegistrationId)
                }),
                contentType: 'application/json',
                success: function (r) {
                    if (r.success && r.data) {
                        renderFullReceipt(r.data);
                    } else {
                        Swal.fire('Error', r.message || 'Receipt data not found.', 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Failed to load full receipt.', 'error');
                }
            });
        }

        function renderFullReceipt(d) {
            var now = new Date();
            $('#generatedDate').text(now.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }));

            $('#schoolName').text(d.schoolName || 'School Name');
            $('#studentName').text(d.studentName || '--');
            $('#admissionNo').text(d.admissionNo || '--');
            $('#className').text(d.className || '--');
            $('#arm').text(d.arm || '--');
            $('#sessionTermLabel').text((d.sessionName || '') + ' - ' + (d.termName || ''));

            var expected = parseFloat(d.totalExpected) || 0;
            var paid = parseFloat(d.totalPaid) || 0;
            var bal = expected - paid;

            $('#totalExpected').text(expected.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            $('#totalPaid').text(paid.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            $('#outstanding').text(bal.toLocaleString('en-US', { minimumFractionDigits: 2 }));

            var bdBody = $('#breakdownBody');
            bdBody.empty();
            var totExpected = 0, totPaid = 0, totBal = 0;
            if (d.breakdown && d.breakdown.length) {
                d.breakdown.forEach(function (b) {
                    var exp = parseFloat(b.expected) || 0;
                    var pd = parseFloat(b.paid) || 0;
                    var bl = exp - pd;
                    totExpected += exp;
                    totPaid += pd;
                    totBal += bl;
                    bdBody.append('<tr>' +
                        '<td>' + (b.categoryName || '--') + '</td>' +
                        '<td>' + (b.itemName || '--') + '</td>' +
                        '<td class="text-end">' + exp.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '</td>' +
                        '<td class="text-end">' + pd.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '</td>' +
                        '<td class="text-end">' + bl.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '</td>' +
                        '</tr>');
                });
            }
            $('#totalExpectedFoot').text(totExpected.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            $('#totalPaidFoot').text(totPaid.toLocaleString('en-US', { minimumFractionDigits: 2 }));
            $('#totalBalanceFoot').text(totBal.toLocaleString('en-US', { minimumFractionDigits: 2 }));

            var histBody = $('#historyBody');
            histBody.empty();
            var histTotal = 0;
            var statusMap = { Completed: 'success', Pending: 'warning text-dark', Failed: 'danger', Reversed: 'secondary' };
            if (d.payments && d.payments.length) {
                d.payments.forEach(function (p, i) {
                    var amt = parseFloat(p.amount) || 0;
                    histTotal += amt;
                    var dt = p.date ? new Date(p.date) : null;
                    var dateStr = dt ? dt.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : '--';
                    histBody.append('<tr>' +
                        '<td>' + (i + 1) + '</td>' +
                        '<td class="font-monospace">' + (p.reference || '--') + '</td>' +
                        '<td>' + dateStr + '</td>' +
                        '<td class="text-end">' + amt.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '</td>' +
                        '<td><span class="badge bg-' + (statusMap[p.status] || 'secondary') + '">' + (p.status || '--') + '</span></td>' +
                        '</tr>');
                });
            }
            $('#historyTotal').text(histTotal.toLocaleString('en-US', { minimumFractionDigits: 2 }));
        }

        $(document).ready(function () {
            loadFullReceipt();
        });
    </script>
}
