@page
@model UpgradedSchoolManagementWeb.Pages.Admin.Finance.Payments.DetailModel
@{
    ViewData["Title"] = "Payment Detail";
}

@section Sheets {
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<div class="mgmt-page">

    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-receipt-cutoff me-2" style="color:var(--accent)"></i>Payment Detail</div>
            <div class="mgmt-sub" id="pageSub">View payment information and take action</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Payments
            </a>
            <a id="receiptLink" href="#" class="btn btn-outline-primary" style="display:none">
                <i class="bi bi-printer me-1"></i> Receipt
            </a>
            <a id="fullReceiptLink" href="#" class="btn btn-outline-success" style="display:none">
                <i class="bi bi-receipt me-1"></i> Full Term Receipt
            </a>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-lg-4">

            <div class="mgmt-card fade-in">
                <div class="mgmt-card-head">
                    <h6><i class="bi bi-person-vcard me-2" style="color:var(--accent2)"></i>Student Information</h6>
                </div>
                <div class="mgmt-card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr><td class="text-muted ps-0">Name</td><td class="fw-semibold" id="studentName">--</td></tr>
                        <tr><td class="text-muted ps-0">Admission No</td><td class="fw-semibold" id="admissionNo">--</td></tr>
                        <tr><td class="text-muted ps-0">Class</td><td class="fw-semibold" id="className">--</td></tr>
                        <tr><td class="text-muted ps-0">Session / Term</td><td class="fw-semibold" id="sessionTerm">--</td></tr>
                    </table>
                </div>
            </div>

            <div class="mgmt-card fade-in mt-4">
                <div class="mgmt-card-head">
                    <h6><i class="bi bi-info-circle me-2" style="color:var(--accent2)"></i>Payment Details</h6>
                </div>
                <div class="mgmt-card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr><td class="text-muted ps-0">Reference</td><td class="fw-semibold font-monospace" id="reference">--</td></tr>
                        <tr><td class="text-muted ps-0">Total Amount</td><td class="fw-semibold" id="totalAmount">--</td></tr>
                        <tr><td class="text-muted ps-0">Status</td><td id="statusBadge">--</td></tr>
                        <tr><td class="text-muted ps-0">State</td><td id="stateBadge">--</td></tr>
                        <tr><td class="text-muted ps-0">Payment Date</td><td class="fw-semibold" id="paymentDate">--</td></tr>
                        <tr><td class="text-muted ps-0">Narration</td><td id="narration">--</td></tr>
                        <tr><td class="text-muted ps-0">Recorded By</td><td class="fw-semibold" id="recordedBy">--</td></tr>
                    </table>
                </div>
            </div>

            <div class="mgmt-card fade-in mt-4">
                <div class="mgmt-card-head">
                    <h6><i class="bi bi-shield-check me-2" style="color:var(--accent2)"></i>Actions</h6>
                </div>
                <div class="mgmt-card-body">
                    <div id="pendingActions" style="display:none">
                        <p class="small text-muted mb-3">This payment is pending approval. Review the details and take action.</p>
                        <button class="btn btn-warning w-100 mb-2" onclick="editPayment()">
                            <i class="bi bi-pencil me-1"></i> Edit Amount
                        </button>
                        <button class="btn btn-success w-100 mb-2" onclick="approvePayment()">
                            <i class="bi bi-check-circle me-1"></i> Approve Payment
                        </button>
                        <button class="btn btn-danger w-100" onclick="rejectPayment()">
                            <i class="bi bi-x-circle me-1"></i> Reject Payment
                        </button>
                    </div>
                    <div id="completedActions" style="display:none">
                        <p class="small text-success mb-2"><i class="bi bi-check-circle-fill me-1"></i> Payment has been approved.</p>
                        <button class="btn btn-outline-primary w-100" onclick="window.open(document.getElementById('receiptLink').href, '_blank')">
                            <i class="bi bi-printer me-1"></i> Print Receipt
                        </button>
                    </div>
                    <div id="rejectedActions" style="display:none">
                        <p class="small text-danger mb-2"><i class="bi bi-x-circle-fill me-1"></i> Payment was rejected.</p>
                    </div>
                    <hr />
                    <a id="evidenceLink" href="#" class="btn btn-outline-secondary w-100" style="display:none" target="_blank">
                        <i class="bi bi-paperclip me-1"></i> View Evidence
                    </a>
                </div>
            </div>

        </div>

        <div class="col-lg-8">

            <div class="mgmt-card fade-in">
                <div class="mgmt-card-head">
                    <h6><i class="bi bi-receipt me-2" style="color:var(--accent2)"></i>Payment Items</h6>
                </div>
                <div class="mgmt-card-body">
                    <div class="table-responsive">
                        <table id="itemsTable" class="table table-sm">
                            <thead>
                                <tr>
                                    <th>S/N</th>
                                    <th>Item</th>
                                    <th>Category</th>
                                    <th class="text-end">Amount Paid</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td colspan="3" class="text-end">Total</td>
                                    <td class="text-end" id="totalAmountDisplay">0.00</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script>
        const params = new URLSearchParams(window.location.search);
        const paymentId = params.get('id');
        let editPaymentData = null;

        if (!paymentId) {
            Swal.fire('Error', 'No payment ID provided.', 'error').then(function () {
                window.location.href = '/Admin/Finance/Payments/Index';
            });
        }

        function loadPaymentDetail() {
            $.ajax({
                url: '/V1/GetPaymentDetail?paymentId=' + paymentId,
                type: 'GET',
                success: function (r) {
                    if (r.success && r.data) {
                        renderPayment(r.data);
                    } else {
                        Swal.fire('Error', r.message || 'Payment not found.', 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Failed to load payment details.', 'error');
                }
            });
        }

        function renderPayment(d) {
            editPaymentData = d;

            $('#studentName').text(d.studentName || '--');
            $('#admissionNo').text(d.admissionNo || '--');
            $('#className').text(d.className || '--');
            $('#sessionTerm').text((d.sessionName || '') + ' - ' + (d.termName || ''));
            $('#reference').text(d.reference || '--');
            $('#totalAmount').text(d.totalAmount ? parseFloat(d.totalAmount).toLocaleString('en-US', { minimumFractionDigits: 2 }) : '--');
            $('#paymentDate').text(d.paymentDate || '--');
            $('#narration').text(d.narration || '<span class="text-muted fst-italic">None</span>');
            $('#recordedBy').text(d.recordedBy || '--');

            var statusMap = { Completed: 'success', Pending: 'warning text-dark', Failed: 'danger', Reversed: 'secondary' };
            var stateMap = { Approved: 'success', Pending: 'warning text-dark', Rejected: 'danger', Cancelled: 'secondary' };

            $('#statusBadge').html('<span class="badge bg-' + (statusMap[d.status] || 'secondary') + '">' + (d.status || '--') + '</span>');
            $('#stateBadge').html('<span class="badge bg-' + (stateMap[d.state] || 'secondary') + '">' + (d.state || '--') + '</span>');

            if (d.state === 'Pending') {
                $('#pendingActions').show();
            } else if (d.state === 'Approved') {
                $('#completedActions').show();
            } else if (d.state === 'Rejected') {
                $('#rejectedActions').show();
            }

            var receiptUrl = '/Admin/Finance/Payments/Receipt?id=' + paymentId;
            $('#receiptLink').attr('href', receiptUrl).show();
            if (d.termRegId) {
            var fullReceiptUrl = '/Admin/Finance/Payments/full-receipt/' + d.termRegId;

            $('#fullReceiptLink')
                .attr('href', fullReceiptUrl)
                .attr('target', '_blank')
                .attr('rel', 'noopener noreferrer')
                .show();
            }

            if (d.evidenceFilePath) {
                $('#evidenceLink').attr('href', d.evidenceFilePath).show();
            }

            var total = 0;
            var tbody = $('#itemsTable tbody');
            var lineItems = d.lineItems || [];
            if (lineItems.length) {
                lineItems.forEach(function (item, i) {
                    var amt = parseFloat(item.amountPaid) || 0;
                    total += amt;
                    tbody.append('<tr>' +
                        '<td>' + (i + 1) + '</td>' +
                        '<td>' + (item.itemName || '--') + '</td>' +
                        '<td>' + (item.categoryName || '--') + '</td>' +
                        '<td class="text-end">' + amt.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '</td>' +
                        '</tr>');
                });
            }
            $('#totalAmountDisplay').text(total.toLocaleString('en-US', { minimumFractionDigits: 2 }));
        }

        function approvePayment() {
            Swal.fire({
                title: 'Approve Payment?',
                text: 'This will confirm the payment as completed.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: 'var(--accent3)',
                cancelButtonColor: 'var(--muted)',
                confirmButtonText: 'Yes, approve'
            }).then(function (result) {
                if (result.isConfirmed) {
                    var payload = {
                        PaymentId: parseInt(paymentId),
                        PaymentState: 2,
                        RejectMessage: null
                    };
                    $.ajax({
                        url: '/V1/UpdatePaymentState',
                        type: 'POST',
                        data: JSON.stringify(payload),
                        contentType: 'application/json',
                        success: function (r) {
                            if (r.success) {
                                Swal.fire({ icon: 'success', title: 'Approved!', text: r.message, timer: 2000, showConfirmButton: false })
                                    .then(function () { location.reload(); });
                            } else {
                                Swal.fire('Error', r.message || 'Approval failed.', 'error');
                            }
                        },
                        error: function () { Swal.fire('Error', 'An error occurred.', 'error'); }
                    });
                }
            });
        }

        function rejectPayment() {
            Swal.fire({
                title: 'Reject Payment?',
                text: 'Provide a reason for rejection.',
                icon: 'warning',
                input: 'textarea',
                inputPlaceholder: 'Reason for rejection...',
                inputAttributes: { required: 'required' },
                showCancelButton: true,
                confirmButtonColor: 'var(--accent4)',
                cancelButtonColor: 'var(--muted)',
                confirmButtonText: 'Yes, reject'
            }).then(function (result) {
                if (result.isConfirmed && result.value) {
                    var payload = {
                        PaymentId: parseInt(paymentId),
                        PaymentState: 3,
                        RejectMessage: result.value
                    };
                    $.ajax({
                        url: '/V1/UpdatePaymentState',
                        type: 'POST',
                        data: JSON.stringify(payload),
                        contentType: 'application/json',
                        success: function (r) {
                            if (r.success) {
                                Swal.fire({ icon: 'success', title: 'Rejected', text: r.message, timer: 2000, showConfirmButton: false })
                                    .then(function () { location.reload(); });
                            } else {
                                Swal.fire('Error', r.message || 'Rejection failed.', 'error');
                            }
                        },
                        error: function () { Swal.fire('Error', 'An error occurred.', 'error'); }
                    });
                } else if (result.isConfirmed && !result.value) {
                    Swal.fire('Validation', 'Please provide a reason for rejection.', 'warning');
                }
            });
        }

        function editPayment() {
            var d = editPaymentData;
            if (!d) return;

            var currentAmount = parseFloat(d.totalAmount) || 0;

            Swal.fire({
                title: 'Edit Payment Amount',
                html:
                    '<div class="text-start">' +
                    '<label class="form-label small">Reference: <strong>' + d.reference + '</strong></label>' +
                    '<label class="form-label small mt-2">New Amount (&#8358;)</label>' +
                    '<input id="swalEditAmount" class="form-control" type="number" step="0.01" min="0.01" value="' + currentAmount.toFixed(2) + '" />' +
                    '<label class="form-label small mt-2">Narration</label>' +
                    '<textarea id="swalEditNarration" class="form-control" rows="2" maxlength="120">' + (d.narration || '') + '</textarea>' +
                    '</div>',
                showCancelButton: true,
                confirmButtonText: 'Save Changes',
                cancelButtonText: 'Cancel',
                confirmButtonColor: 'var(--accent3)',
                preConfirm: function () {
                    var amt = parseFloat($('#swalEditAmount').val());
                    if (!amt || amt <= 0) {
                        Swal.showValidationMessage('Amount must be greater than zero.');
                        return false;
                    }
                    return {
                        newAmount: amt,
                        narration: $('#swalEditNarration').val().trim() || null
                    };
                }
            }).then(function (result) {
                if (!result.isConfirmed) return;

                var payload = {
                    PaymentId: parseInt(paymentId),
                    NewAmount: result.value.newAmount,
                    Narration: result.value.narration
                };

                Swal.showLoading();

                $.ajax({
                    url: '/V1/UpdatePaymentAmount',
                    type: 'POST',
                    data: JSON.stringify(payload),
                    contentType: 'application/json',
                    success: function (r) {
                        if (r.success) {
                            Swal.fire({ icon: 'success', title: 'Updated!', text: r.message, timer: 2000, showConfirmButton: false })
                                .then(function () { location.reload(); });
                        } else {
                            Swal.fire('Error', r.message || 'Update failed.', 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Error', 'An error occurred while updating payment.', 'error');
                    }
                });
            });
        }

        $(document).ready(function () {
            loadPaymentDetail();
        });
    </script>
}
