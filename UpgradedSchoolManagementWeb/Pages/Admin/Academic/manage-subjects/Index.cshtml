@page
@model UpgradedSchoolManagementWeb.Pages.Admin.Academic.manage_subjects.IndexModel
@{
    ViewData["Title"] = "Manage Subjects";
}
@section Sheets {
    <partial name="_DataTablesSheetFiles" />
}
<div class="mgmt-page">

    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-journal-bookmark-fill me-2" style="color:var(--accent)"></i>Subjects</div>
            <div class="mgmt-sub">Manage academic subjects offered in your school</div>
        </div>
        <button type="button" class="btn-mgmt-primary" onclick="showCreateModal()">
            <i class="bi bi-plus-lg"></i> Add Subject
        </button>
    </div>

    <div class="mgmt-card fade-in">
        <div class="mgmt-card-head">
            <h6><i class="bi bi-table me-2" style="color:var(--accent2)"></i>All Subjects</h6>
        </div>
        <div class="mgmt-card-body">
            <div class="table-responsive">
                <table id="subjectsTable" class="table w-100">
                    <thead>
                        <tr>
                            <th>S/N</th>
                            <th>Subject Name</th>
                            <th>Code</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<!-- Subject Modal -->
<div class="modal fade" id="subjectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Subject</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="subjectForm">
                <div class="modal-body">
                    <input type="hidden" id="subjectId" value="0" />
                    <div class="mb-3">
                        <label for="subjectName" class="form-label">Subject Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="subjectName" placeholder="e.g., Mathematics" required />
                    </div>
                    <div class="mb-3">
                        <label for="subjectCode" class="form-label">Subject Code</label>
                        <input type="text" class="form-control" id="subjectCode" placeholder="e.g., MATH" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_DataTablesScriptsFiles" />
    <script>
        let subjectsTable;

        $(document).ready(function () {
            initDataTable();
            $('#subjectForm').on('submit', function (e) { e.preventDefault(); submitForm(); });
        });

        function initDataTable() {
            subjectsTable = $('#subjectsTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/Home/GetSubjects',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) { return JSON.stringify(d); }
                },
                columns: [
                    { data: null, render: function (d, t, r, m) { return m.row + m.settings._iDisplayStart + 1; }, orderable: false, width: '50px' },
                    { data: 'name' },
                    { data: 'code', width: '110px' },
                    {
                        data: 'isActive',
                        render: function (d) { return d ? '<span class="badge-active">Active</span>' : '<span class="badge-inactive">Inactive</span>'; },
                        width: '100px'
                    },
                    { data: 'createdDate', render: function (d) { if (!d) return ''; var dt = new Date(d); return dt.getDate().toString().padStart(2,'0') + '-' + dt.toLocaleString('en-GB',{month:'short'}) + '-' + dt.getFullYear(); }, width: '130px' },
                    {
                        data: 'id',
                        render: function (data, type, row) {
                            const statusText = row.isActive ? 'Deactivate' : 'Activate';
                            const statusIcon = row.isActive ? 'bi-slash-circle' : 'bi-check-circle';
                            return `<div class="dropdown text-center">
                                <button class="btn-action" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="showEditModal(${data},'${row.name}','${row.code || ''}')"><i class="bi bi-pencil-square"></i>Edit</a></li>
                                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="toggleStatus(${data})"><i class="bi ${statusIcon}"></i>${statusText}</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="confirmDelete(${data})"><i class="bi bi-trash3"></i>Delete</a></li>
                                </ul>
                            </div>`;
                        },
                        orderable: false,
                        width: '80px'
                    }
                ],
                order: [[4, 'desc']]
            });
        }

        function showCreateModal() {
            $('#modalTitle').text('Add Subject');
            $('#subjectId').val('0'); $('#subjectName').val(''); $('#subjectCode').val('');
            $('#subjectModal').modal('show');
        }

        function showEditModal(id, name, code) {
            $('#modalTitle').text('Edit Subject');
            $('#subjectId').val(id); $('#subjectName').val(name); $('#subjectCode').val(code || '');
            $('#subjectModal').modal('show');
        }

        function submitForm() {
            const id = $('#subjectId').val();
            const name = $('#subjectName').val().trim();
            const code = $('#subjectCode').val().trim();
            if (!name) return;
            const url = id === '0' ? '/V1/CreateSubject' : '/V1/UpdateSubject';
            const data = id === '0' ? { Name: name, Code: code } : { Id: parseInt(id), Name: name, Code: code };
            $.ajax({
                url: url, type: 'POST', data: JSON.stringify(data), contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) { if (r.success) { Swal.fire('Success', r.message, 'success'); $('#subjectModal').modal('hide'); subjectsTable.ajax.reload(); } else { Swal.fire('Error', r.message, 'error'); } },
                error: function () { Swal.fire('Error', 'An error occurred. Please try again.', 'error'); }
            });
        }

        function toggleStatus(id) {
            Swal.fire({ title: 'Change Status?', text: 'Are you sure you want to change this subject status?', icon: 'question', showCancelButton: true, confirmButtonColor: 'var(--accent)', cancelButtonColor: 'var(--muted)', confirmButtonText: 'Yes, change it!' }).then(function (result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/V1/ToggleSubjectStatus', type: 'POST', data: JSON.stringify({ Id: id }), contentType: 'application/json',
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (r) { if (r.success) { Swal.fire('Done', r.message, 'success'); subjectsTable.ajax.reload(); } else { Swal.fire('Error', r.message, 'error'); } },
                        error: function () { Swal.fire('Error', 'An error occurred.', 'error'); }
                    });
                }
            });
        }

        function confirmDelete(id) {
            Swal.fire({ title: 'Delete Subject?', text: 'This action cannot be undone.', icon: 'warning', showCancelButton: true, confirmButtonColor: 'var(--accent4)', cancelButtonColor: 'var(--muted)', confirmButtonText: 'Yes, delete it!' }).then(function (result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/V1/DeleteSubject', type: 'POST', data: JSON.stringify({ Id: id }), contentType: 'application/json',
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (r) { if (r.success) { Swal.fire('Deleted!', r.message, 'success'); subjectsTable.ajax.reload(); } else { Swal.fire('Error', r.message, 'error'); } },
                        error: function () { Swal.fire('Error', 'An error occurred.', 'error'); }
                    });
                }
            });
        }
    </script>
}
