@page
@model UpgradedSchoolManagementWeb.Pages.Admin.Academic.manage_school.IndexModel
@{
    ViewData["Title"] = "Manage School Classes";
}
@section Sheets {
    <partial name="_DataTablesSheetFiles" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}
<div class="mgmt-page">

    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-mortarboard-fill me-2" style="color:var(--accent)"></i>School Classes</div>
            <div class="mgmt-sub">Manage class levels for your school</div>
        </div>
        <button type="button" class="btn-mgmt-primary" onclick="showCreateModal()">
            <i class="bi bi-plus-lg"></i> Add Class
        </button>
    </div>

    <div class="mgmt-card fade-in">
        <div class="mgmt-card-head">
            <h6><i class="bi bi-table me-2" style="color:var(--accent2)"></i>All Classes</h6>
        </div>
        <div class="mgmt-card-body">
            <div class="table-responsive">
                <table id="classesTable" class="table w-100">
                    <thead>
                        <tr>
                            <th>S/N</th>
                            <th>Class Name</th>
                            <th>Result Type</th>
                            <th>Display Order</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<!-- Class Modal -->
<div class="modal fade" id="classModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Class</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="classForm">
                <div class="modal-body">
                    <input type="hidden" id="classId" value="0" />
                    <div class="mb-3">
                        <label for="className" class="form-label">Class Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="className" placeholder="e.g., JSS 1" required />
                    </div>
                    <div class="mb-3">
                        <label for="resultType" class="form-label">Result Type</label>
                        <select class="form-select" id="resultType">
                            <option value="0">---Select Result Type---</option>
                            <option value="1">Nursery</option>
                            <option value="2">Primary</option>
                            <option value="3">JSS</option>
                            <option value="4">SSS</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="displayOrder" class="form-label">Display Order</label>
                        <input type="number" class="form-control" id="displayOrder" value="0" min="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_DataTablesScriptsFiles" />
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
        let classesTable;

        $(document).ready(function () {
            initDataTable();
            $('#classForm').on('submit', function (e) { e.preventDefault(); submitForm(); });
        });

        function initDataTable() {
            classesTable = $('#classesTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/Home/GetClasses',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) { return JSON.stringify(d); }
                },
                columns: [
                    { data: null, render: function (d, t, r, m) { return m.row + m.settings._iDisplayStart + 1; }, orderable: false, width: '50px' },
                    { data: 'name' },
                    {
                        data: 'resulttype',
                        render: function (d) {
                            if (d === 0) return '<span class="badge bg-secondary">Not Set</span>';
                            var labels = { 1: 'Nursery', 2: 'Primary', 3: 'JSS', 4: 'SSS' };
                            return labels[d] || 'Unknown (' + d + ')';
                        },
                        width: '120px'
                    },
                    { data: 'displayOrder', width: '130px' },
                    {
                        data: 'isActive',
                        render: function (d) { return d ? '<span class="badge-active">Active</span>' : '<span class="badge-inactive">Inactive</span>'; },
                        width: '100px'
                    },
                    { data: 'createdDate', render: function (d) { if (!d) return ''; var dt = new Date(d); return dt.getDate().toString().padStart(2,'0') + '-' + dt.toLocaleString('en-GB',{month:'short'}) + '-' + dt.getFullYear(); }, width: '130px' },
                    {
                        data: 'id',
                        render: function (data, type, row) {
                            const statusText = row.isActive ? 'Deactivate' : 'Activate';
                            const statusIcon = row.isActive ? 'bi-slash-circle' : 'bi-check-circle';
                            return `<div class="dropdown text-center">
                                <button class="btn-action" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="showEditModal(${data},'${row.name}',${row.displayOrder},${row.resulttype})"><i class="bi bi-pencil-square"></i>Edit</a></li>
                                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="toggleStatus(${data})"><i class="bi ${statusIcon}"></i>${statusText}</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="confirmDelete(${data})"><i class="bi bi-trash3"></i>Delete</a></li>
                                </ul>
                            </div>`;
                        },
                        orderable: false,
                        width: '80px'
                    }
                ],
                order: [[4, 'desc']]
            });
        }

        function showCreateModal() {
            $('#modalTitle').text('Add Class');
            $('#classId').val('0'); $('#className').val(''); $('#resultType').val('0'); $('#displayOrder').val('0');
            $('#classModal').modal('show');
        }

        function showEditModal(id, name, displayOrder, resultType) {
            $('#modalTitle').text('Edit Class');
            $('#classId').val(id); $('#className').val(name); $('#displayOrder').val(displayOrder);
            $('#resultType').val(resultType != null ? resultType : '0');
            $('#classModal').modal('show');
        }

        function submitForm() {
            const id = $('#classId').val();
            const name = $('#className').val().trim();
            const resultType = parseInt($('#resultType').val()) || 0;
            const displayOrder = parseInt($('#displayOrder').val()) || 0;
            if (!name) return;
            const url = id === '0' ? '/V1/CreateClass' : '/V1/UpdateClass';
            const data = id === '0'
                ? { Name: name, DisplayOrder: displayOrder, ResultType: resultType }
                : { Id: parseInt(id), Name: name, DisplayOrder: displayOrder, ResultType: resultType };
            const btn = $('#classForm button[type="submit"]');
            btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat me-1 spinner"></i> Saving...');
            $.ajax({
                url: url, type: 'POST', data: JSON.stringify(data), contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save');
                    if (r.success) {
                        $('#classModal').modal('hide');
                        Swal.fire({ icon: 'success', title: 'Success', text: r.message, timer: 2000, showConfirmButton: false });
                        classesTable.ajax.reload();
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: r.message });
                    }
                },
                error: function () {
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save');
                    Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred. Please try again.' });
                }
            });
        }

        function toggleStatus(id) {
            Swal.fire({ title: 'Change Status?', text: 'Are you sure you want to change this class status?', icon: 'question', showCancelButton: true, confirmButtonColor: 'var(--accent)', cancelButtonColor: 'var(--muted)', confirmButtonText: 'Yes, change it!' }).then(function (result) {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Processing...', allowOutsideClick: false, allowEscapeKey: false, showConfirmButton: false, didOpen: function () { Swal.showLoading(); } });
                    $.ajax({
                        url: '/V1/ToggleClassStatus', type: 'POST', data: JSON.stringify({ Id: id }), contentType: 'application/json',
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (r) {
                            if (r.success) { Swal.fire({ icon: 'success', title: 'Done', text: r.message, timer: 2000, showConfirmButton: false }); classesTable.ajax.reload(); }
                            else { Swal.fire({ icon: 'error', title: 'Error', text: r.message }); }
                        },
                        error: function () { Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred.' }); }
                    });
                }
            });
        }

        function confirmDelete(id) {
            Swal.fire({ title: 'Delete Class?', text: 'This action cannot be undone.', icon: 'warning', showCancelButton: true, confirmButtonColor: 'var(--accent4)', cancelButtonColor: 'var(--muted)', confirmButtonText: 'Yes, delete it!' }).then(function (result) {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Deleting...', allowOutsideClick: false, allowEscapeKey: false, showConfirmButton: false, didOpen: function () { Swal.showLoading(); } });
                    $.ajax({
                        url: '/V1/DeleteClass', type: 'POST', data: JSON.stringify({ Id: id }), contentType: 'application/json',
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (r) {
                            if (r.success) { Swal.fire({ icon: 'success', title: 'Deleted!', text: r.message, timer: 2000, showConfirmButton: false }); classesTable.ajax.reload(); }
                            else { Swal.fire({ icon: 'error', title: 'Error', text: r.message }); }
                        },
                        error: function () { Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred.' }); }
                    });
                }
            });
        }
    </script>
}
