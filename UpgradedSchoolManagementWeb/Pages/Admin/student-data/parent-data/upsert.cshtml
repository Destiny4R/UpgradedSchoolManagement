@page
@model UpgradedSchoolManagementWeb.Pages.admin.student_data.parent_data.upsertModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Parent/Guardian" : "Add Parent/Guardian";
    var p = Model.Parent;
}

<div class="mgmt-page">

    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title">
                <i class="bi @(Model.IsEdit ? "bi-pencil-square" : "bi-person-plus-fill") me-2" style="color:var(--accent)"></i>
                @ViewData["Title"]
            </div>
            <div class="mgmt-sub">@(Model.IsEdit ? "Update parent/guardian information" : "Register a new parent or guardian")</div>
        </div>
        <a asp-page="index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    @if (!Model.IsEdit)
    {
        <div class="mgmt-card fade-in">
            <div class="mgmt-card-body">
                <h6 class="mb-3" style="color:var(--accent2)">
                    <i class="bi bi-search me-2"></i>Find Student
                </h6>
                <p class="text-muted small mb-3">Search for a student by Admission Number or Email to link this parent/guardian to them.</p>
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label class="form-label">Admission Number / Email</label>
                        <input type="text" class="form-control" id="studentSearch" placeholder="Type admission number or email..." />
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-outline-primary w-100" id="searchStudentBtn">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>
                </div>
                <div id="studentNotFound" class="mt-3 d-none">
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        <span id="studentNotFoundMsg">No student found with that admission number or email.</span>
                    </div>
                </div>
                <input type="hidden" id="selectedStudentId" value="0" />
            </div>
        </div>
    }

    <div class="mgmt-card fade-in @(Model.IsEdit ? "" : "d-none")" id="parentFormContainer">
        <div class="mgmt-card-body">
            <form id="parentForm">
                <input type="hidden" id="parentId" value="@(p?.Id ?? 0)" />
                <input type="hidden" id="selectedStudentIdForm" value="0" />

                @* Linked Student Info Card (shown only in Add mode after search) *@
                <div id="linkedStudentSection" class="@(Model.IsEdit ? "d-none" : "") mb-4">
                    <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, var(--accent, #4f46e5) 0%, var(--accent2, #7c3aed) 100%); border-radius: 12px;">
                        <div class="card-body py-3 px-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:48px;height:48px;background:rgba(255,255,255,0.2);">
                                    <i class="bi bi-person-vcard-fill fs-4 text-white"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="text-white opacity-75 small mb-1" style="letter-spacing:.05em;text-transform:uppercase;font-size:.7rem;">Linking Parent/Guardian to Student</div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="fw-bold text-white fs-6" id="linkedStudentName">—</span>
                                        <span class="badge text-white px-2 py-1" id="linkedStudentAdmission"
                                              style="background:rgba(255,255,255,0.25);border-radius:6px;font-size:.78rem;">—</span>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-sm ms-auto" id="clearStudentBtn"
                                        style="background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.35);border-radius:8px;">
                                    <i class="bi bi-arrow-repeat me-1"></i> Change Student
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="mb-3" style="color:var(--accent2)"><i class="bi bi-person-lines-fill me-2"></i>Personal Details</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="fullName" value="@(p?.FullName)" placeholder="Full name of parent/guardian" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Relationship <span class="text-danger">*</span></label>
                        <select class="form-select" id="relationship" required>
                            <option value="">Select relationship…</option>
                            @foreach (var rel in new[] { "Father", "Mother", "Guardian", "Aunt", "Uncle", "Grandfather", "Grandmother", "Sibling", "Other" })
                            {
                                if (p?.Relationship == rel)
                                {
                                    <option value="@rel" selected>@rel</option>
                                }
                                else
                                {
                                    <option value="@rel">@rel</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Occupation</label>
                        <input type="text" class="form-control" id="occupation" value="@(p?.Occupation)" placeholder="e.g. Teacher, Engineer" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Address</label>
                        <input type="text" class="form-control" id="address" value="@(p?.Address)" placeholder="Home or work address" />
                    </div>
                </div>

                <h6 class="mb-3 mt-4" style="color:var(--accent2)"><i class="bi bi-telephone-fill me-2"></i>Contact Information</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Phone Number 1 <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control" id="phone1" value="@(p?.Phone1)" placeholder="e.g. 08031234567" required />
                        <div class="form-text">Primary contact number (at least 10 digits). This must be unique.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone Number 2</label>
                        <input type="tel" class="form-control" id="phone2" value="@(p?.Phone2)" placeholder="Optional secondary number" />
                        <div class="form-text">Alternate contact number (optional).</div>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4" id="submitBtn">
                        <i class="bi bi-check2-circle me-1"></i> @(Model.IsEdit ? "Update Parent" : "Save Parent")
                    </button>
                    <a asp-page="index" class="btn btn-secondary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const isEdit = @(Model.IsEdit ? "true" : "false");

        // ── Student Search ──────────────────────────────────────────────────────

        $('#searchStudentBtn').on('click', function () {
            const query = $('#studentSearch').val().trim();
            if (!query) {
                Swal.fire('Input Required', 'Please enter an admission number or email.', 'warning');
                return;
            }

            // Show a loading state on the button
            $('#searchStudentBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Searching...');

            $.ajax({
                url: '/V1/SearchStudent',
                type: 'POST',
                data: JSON.stringify({ Query: query }),
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (r) {
                    if (r.success) {
                        const s = r.data;
                        // Sync both hidden fields (search card + form)
                        $('#selectedStudentId').val(s.Id);
                        $('#selectedStudentIdForm').val(s.Id);

                        // Populate the prominent student card
                        $('#linkedStudentName').text(s.fullName || '—');
                        $('#linkedStudentAdmission').text(s.admissionNumber || '—');

                        // Show the form, hide not-found banner
                        $('#parentFormContainer').removeClass('d-none').addClass('fade-in');
                        $('#linkedStudentSection').removeClass('d-none');
                        $('#studentNotFound').addClass('d-none');

                        // Scroll to the form smoothly
                        setTimeout(function () {
                            document.getElementById('parentFormContainer').scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }, 150);
                    } else {
                        $('#selectedStudentId').val(0);
                        $('#selectedStudentIdForm').val(0);
                        $('#studentNotFoundMsg').text(r.message);
                        $('#parentFormContainer').addClass('d-none');
                        $('#linkedStudentSection').addClass('d-none');
                        $('#studentNotFound').removeClass('d-none');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'Search failed. Please try again.', 'error');
                },
                complete: function () {
                    $('#searchStudentBtn').prop('disabled', false).html('<i class="bi bi-search me-1"></i> Search');
                }
            });
        });

        $('#clearStudentBtn').on('click', function () {
            $('#studentSearch').val('');
            $('#selectedStudentId').val(0);
            $('#selectedStudentIdForm').val(0);
            $('#linkedStudentName').text('—');
            $('#linkedStudentAdmission').text('—');
            $('#linkedStudentSection').addClass('d-none');
            $('#parentFormContainer').addClass('d-none');
            $('#studentNotFound').addClass('d-none');
            // Scroll back to the search card
            setTimeout(function () {
                document.getElementById('studentSearch').scrollIntoView({ behavior: 'smooth', block: 'center' });
                document.getElementById('studentSearch').focus();
            }, 150);
        });

        $('#studentSearch').on('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                $('#searchStudentBtn').trigger('click');
            }
        });

        // ── Form Submit ─────────────────────────────────────────────────────────

        let conflictData = null;

        function buildPayload() {
            return {
                FullName:     $('#fullName').val().trim(),
                Relationship: $('#relationship').val(),
                Occupation:   $('#occupation').val().trim() || null,
                Address:      $('#address').val().trim() || null,
                Phone1:       $('#phone1').val().trim(),
                Phone2:       $('#phone2').val().trim() || null
            };
        }

        function doSubmit(url, payload) {
            return $.ajax({
                url: url,
                type: 'POST',
                data: JSON.stringify(payload),
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
            });
        }

        $('#parentForm').on('submit', function (e) {
            e.preventDefault();

            // Use the form-scoped hidden field so the value persists even after scroll
            const studentId = parseInt($('#selectedStudentIdForm').val()) || parseInt($('#selectedStudentId').val()) || 0;
            const isLinking = studentId > 0 && !isEdit;

            if (conflictData) {
                handleConflictSubmit();
                return;
            }

            let payload;
            let url;

            if (isEdit) {
                payload = buildPayload();
                payload.Id = parseInt($('#parentId').val());
                url = '/V1/UpdateParent';
            } else if (isLinking) {
                payload = buildPayload();
                payload.StudentId = studentId;
                url = '/V1/AddOrLinkParent';
            } else if (!isEdit) {
                payload = buildPayload();
                url = '/V1/CreateParent';
            }

            $('#submitBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Saving...');

            doSubmit(url, payload)
                .then(function (r) {
                    var isSuccess = r.Success !== undefined ? r.Success : r.success;
                    var isConflict = r.IsConflict !== undefined ? r.IsConflict : r.isConflict;
                    var msg = r.Message || r.message || '';
                    if (isSuccess) {
                        Swal.fire({ icon: 'success', title: 'Success', text: msg,
                            timer: 1800, showConfirmButton: false })
                            .then(function () { window.location.href = '/Admin/student-data/parent-data/index'; });
                    } else if (isConflict && isLinking) {
                        var parent = r.Parent || r.parent;
                        conflictData = {
                            existingParentId: parent ? parent.Id : 0,
                            studentId: studentId,
                            parentInfo: parent,
                            message: msg
                        };
                        showConflictDialog();
                    } else {
                        Swal.fire('Error', msg, 'error');
                        $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save Parent');
                    }
                })
                .catch(function () {
                    Swal.fire('Error', 'An error occurred. Please try again.', 'error');
                    $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save Parent');
                });
        });

        // ── Conflict Resolution ─────────────────────────────────────────────────

        function showConflictDialog() {
            const p = conflictData.parentInfo;
            const infoHtml =
                '<div class="text-start mb-2">' +
                '<strong>Existing Parent Details:</strong><br>' +
                'Name: ' + p.FullName + '<br>' +
                'Phone: ' + p.Phone1 +
                (p.Phone2 ? ' / ' + p.Phone2 : '') + '<br>' +
                'Relationship: ' + p.Relationship +
                (p.Occupation ? '<br>Occupation: ' + p.Occupation : '') +
                '</div>';

            Swal.fire({
                title: 'Parent Already Exists',
                html: '<p>' + conflictData.message + '</p>' + infoHtml +
                      '<p class="mb-0 mt-2"><strong>Would you like to link this student to the existing parent instead?</strong></p>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, link to existing parent',
                cancelButtonText: 'No, let me change the phone number',
                reverseButtons: true,
                allowOutsideClick: false
            }).then(function (result) {
                if (result.isConfirmed) {
                    handleConflictAccept();
                } else {
                    conflictData = null;
                    $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save Parent');
                    $('#phone1').focus();
                }
            });
        }

        function handleConflictAccept() {
            const payload = {
                StudentId: conflictData.studentId,
                ParentGuardianId: conflictData.existingParentId,
                IsPrimaryContact: true
            };



            $('#submitBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Linking...');

            doSubmit('/V1/LinkParentToStudent', payload)
                .then(function (r) {
                    var isSuccess = r.Success !== undefined ? r.Success : r.success;
                    var msg = r.Message || r.message || '';
                    if (isSuccess) {
                        Swal.fire({ icon: 'success', title: 'Linked!', text: msg,
                            timer: 1800, showConfirmButton: false })
                            .then(function () { window.location.href = '/Admin/student-data/parent-data/index'; });
                    } else {
                        Swal.fire('Error', msg, 'error');
                        $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save Parent');
                    }
                })
                .catch(function () {
                    Swal.fire('Error', 'An error occurred. Please try again.', 'error');
                    $('#submitBtn').prop('disabled', false).html('<i class="bi bi-check2-circle me-1"></i> Save Parent');
                });
        }

        function handleConflictSubmit() {
            const studentId = parseInt($('#selectedStudentIdForm').val()) || parseInt($('#selectedStudentId').val()) || 0;
            const isLinking = studentId > 0 && !isEdit;

            if (conflictData && isLinking) {
                showConflictDialog();
            }
        }
    </script>
}
