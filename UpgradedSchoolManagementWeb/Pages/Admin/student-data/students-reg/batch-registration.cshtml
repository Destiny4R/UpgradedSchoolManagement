@page
@model UpgradedSchoolManagementWeb.Pages.admin.student_data.students_reg.batch_registrationModel
@{

    ViewData["Title"] = "Batch Registration Promotion";
}
@section Sheets {
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}
<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <h2 class="fw-bold">Batch Promotion / Registration</h2>
            <p class="text-muted">Promote students from one term/session to another. Subjects are automatically inherited from their previous registration.</p>
        </div>
    </div>

    <!-- Search Source Registrations -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-search me-2"></i>Find Students (Source Registration)</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label for="srcTerm" class="form-label">Term</label>
                    <select id="srcTerm" class="form-select" asp-items="@Model.SelectionViewModal.Terms">
                        <option value="">---Select Term---</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="srcSession" class="form-label">Session</label>
                    <select id="srcSession" class="form-select" asp-items="@Model.SelectionViewModal.AcademicSession">
                        <option value="">---Select Session---</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="srcClass" class="form-label">Class</label>
                    <select id="srcClass" class="form-select" asp-items="@Model.SelectionViewModal.SchoolClasses">
                        <option value="">---Select Class---</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="srcSubClass" class="form-label">Sub Class</label>
                    <select id="srcSubClass" class="form-select" asp-items="@Model.SelectionViewModal.SubClass">
                        <option value="">---Select Sub Class---</option>
                    </select>
                </div>
                <div class="col-md-2 mt-5">
                    <button id="btnSearch" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Promotion Target Configuration -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-arrow-right-circle me-2"></i>Promotion Target Configuration</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="tgtTerm" class="form-label">Target Term</label>
                    <select id="tgtTerm" class="form-select" asp-items="@Model.SelectionViewModal.Terms">
                        <option value="">---Select Term---</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="tgtSession" class="form-label">Target Session</label>
                    <select id="tgtSession" class="form-select" asp-items="@Model.SelectionViewModal.AcademicSession">
                        <option value="">---Select Session---</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="tgtClass" class="form-label">Target Class</label>
                    <select id="tgtClass" class="form-select" asp-items="@Model.SelectionViewModal.SchoolClasses">
                        <option value="">---Select Class---</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="tgtSubClass" class="form-label">Target Sub Class</label>
                    <select id="tgtSubClass" class="form-select" asp-items="@Model.SelectionViewModal.SubClass">
                        <option value="">---Select Sub Class---</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Students Table & Submit -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-people me-2"></i>Students to Promote</h5>
            <span class="badge bg-secondary" id="studentCount">0 Students</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover border" id="studentsTable">
                    <thead class="table-light">
                        <tr>
                            <th>FullName</th>
                            <th>Session</th>
                            <th>Term</th>
                            <th>Class - Sub Class</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="studentsTableBody">
                        <tr>
                            <td colspan="4" class="text-center text-muted">Use the search above to load students.</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div id="resultsContainer" class="mt-3" style="display:none;"></div>

            <div class="text-end mt-4">
                <button id="btnRegisterAll" class="btn btn-success btn-lg" disabled>
                    <i class="bi bi-check2-all me-1"></i> Register All
                </button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script>
        $(document).ready(function () {
            
            let loadedStudents = [];

            // --- SEARCH LOGIC ---
            $('#btnSearch').on('click', function () {
                const term = $('#srcTerm').val();
                const session = $('#srcSession').val();
                const schoolclass = $('#srcClass').val();
                const subclass = $('#srcSubClass').val();

                if (!term || !session || !schoolclass || !subclass) {
                    Swal.fire('Validation Error', 'Please select all Source Criteria before searching.', 'warning');
                    return;
                }

                const payload = {
                    Term: parseInt(term),
                    SessionId: parseInt(session),
                    SchoolClassId: parseInt(schoolclass),
                    SubClassId: parseInt(subclass)
                };

                const btn = $(this);
                const originalText = btn.html();
                btn.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Searching...').prop('disabled', true);

                $('#studentsTableBody').html('<tr><td colspan="4" class="text-center">Loading...</td></tr>');
                $('#btnRegisterAll').prop('disabled', true);

                $.ajax({
                    url: '/V1/SearchPromotionStudents',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function (res) {
                        btn.html(originalText).prop('disabled', false);

                        if (res.success && res.data && res.data.length > 0) {
                            loadedStudents = res.data;
                            renderTable();
                            $('#btnRegisterAll').prop('disabled', false);
                        } else {
                            loadedStudents = [];
                            $('#studentsTableBody').html('<tr><td colspan="4" class="text-center text-muted">No students found matching these criteria.</td></tr>');
                            $('#studentCount').text('0 Students');
                        }
                    },
                    error: function () {
                        btn.html(originalText).prop('disabled', false);
                        Swal.fire('Error', 'Failed to fetch students.', 'error');
                        $('#studentsTableBody').html('<tr><td colspan="4" class="text-center text-danger">Failed to load data.</td></tr>');
                    }
                });
            });

            // --- RENDER TABLE ---
            function renderTable() {
                let html = '';
                loadedStudents.forEach(function (student) {
                    html += `
                        <tr data-id="${student.id}">
                            <td>${student.fullName} <br><small class="text-muted">${student.regNumber}</small></td>
                            <td>${student.session}</td>
                            <td>${student.term}</td>
                            <td>${student.schoolClass} - ${student.subClass}</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-row" data-id="${student.id}">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </td>
                        </tr>
                    `;
                });
                $('#studentsTableBody').html(html);
                updateCount();
            }

            // --- REMOVE ROW ---
            $(document).on('click', '.btn-remove-row', function () {
                const idToRemove = $(this).data('id');
                // Remove from loaded array
                loadedStudents = loadedStudents.filter(s => s.id !== idToRemove);
                // Remove from DOM
                $(this).closest('tr').fadeOut(300, function() {
                    $(this).remove();
                    updateCount();
                });
            });

            function updateCount() {
                $('#studentCount').text(`${loadedStudents.length} Students`);
                if (loadedStudents.length === 0) {
                    $('#studentsTableBody').html('<tr><td colspan="4" class="text-center text-muted">No students remaining.</td></tr>');
                    $('#btnRegisterAll').prop('disabled', true);
                }
            }

            // --- REGISTER ALL ---
            $('#btnRegisterAll').on('click', function () {
                const tgtTerm = $('#tgtTerm').val();
                const tgtSession = $('#tgtSession').val();
                const tgtClass = $('#tgtClass').val();
                const tgtSubClass = $('#tgtSubClass').val();

                if (!tgtTerm || !tgtSession || !tgtClass || !tgtSubClass) {
                    Swal.fire('Validation Error', 'Please select all Target Configuration options before submitting.', 'warning');
                    return;
                }

                if (loadedStudents.length === 0) {
                    Swal.fire('Warning', 'No students to promote.', 'warning');
                    return;
                }

                const termRegIds = loadedStudents.map(s => s.id);

                const payload = {
                    TermRegIds: termRegIds,
                    Term: parseInt(tgtTerm),
                    SessionId: parseInt(tgtSession),
                    SchoolClassId: parseInt(tgtClass),
                    SubClassId: parseInt(tgtSubClass)
                };

                const btn = $(this);
                const originalText = btn.html();
                btn.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...').prop('disabled', true);
                $('#resultsContainer').hide().empty();

                $.ajax({
                    url: '/V1/BatchPromote',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function (res) {
                        btn.html(originalText).prop('disabled', false);
                        
                        $('#resultsContainer').show();

                        if (res.success) {
                            $('#resultsContainer').html(`
                                <div class="alert alert-success">
                                    <i class="bi bi-check-circle-fill me-2"></i> ${res.message}
                                </div>
                            `);
                            // Clear list
                            loadedStudents = [];
                            renderTable();
                            $('#btnRegisterAll').prop('disabled', true);
                        } else {
                            let alertClass = res.successCount > 0 ? 'alert-warning' : 'alert-danger';
                            let errorsHtml = '';
                            if (res.errors && res.errors.length > 0) {
                                errorsHtml = '<ul class="mb-0 mt-2 text-danger">';
                                res.errors.forEach(e => { errorsHtml += `<li>${e}</li>`; });
                                errorsHtml += '</ul>';
                            }

                            $('#resultsContainer').html(`
                                <div class="alert ${alertClass}">
                                    <i class="bi bi-exclamation-circle-fill me-2"></i> ${res.message}
                                    ${errorsHtml}
                                </div>
                            `);
                        }
                    },
                    error: function () {
                        btn.html(originalText).prop('disabled', false);
                        Swal.fire('Error', 'An unexpected error occurred during promotion. Please try again.', 'error');
                    }
                });
            });

        });
    </script>
}

