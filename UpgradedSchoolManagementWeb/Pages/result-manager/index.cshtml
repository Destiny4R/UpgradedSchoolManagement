@page
@model UpgradedSchoolManagementWeb.Pages.result_manager.indexModel
@{
    ViewData["Title"] = "Manage Result Report";
}
@section Sheets {
    <partial name="_DataTablesSheetFiles" />
    <link href="~/lib/jquery-multiselect-master/jquery.multiselect.css" rel="stylesheet" />
}

<div class="mgmt-page">

    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-people-fill me-2" style="color:var(--accent)"></i>Manage Result Report</div>
            <div class="mgmt-sub">Manage students termly result report</div>
        </div>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#resultExcelModal">
                <i class="bi bi-file-spreadsheet me-1"></i> Assessment Sheet
            </button>
            <a asp-page="assessment" class="btn btn-outline-primary">
                <i class="bi bi-table me-1"></i> View Sheet
            </a>
            <a asp-page="manage-information" class="btn btn-outline-primary">Information</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="mgmt-card">
        <div class="mgmt-title m-3">
            <div class="mgmt-header">
                <div>
                    <div class="input-group">
                        @if (string.IsNullOrEmpty(Model.session))
                        {
                            <span class="input-group-text text-danger">Please goto setting and setup a class</span>
                        }
                        else
                        {
                            <span class="input-group-text">@Model.term</span>
                            <span class="input-group-text">@Model.session</span>
                            <span class="input-group-text">@Model.schoolclass</span>
                        }
                    </div>
                </div>
                <div>
                    <div class="btn-group" role="group">
                        <a asp-page="update-attendance" class="btn btn-outline-secondary">Add Attendance</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#btnSubmitResultExcel').on('click', function () {
                var btn = $(this);
                var sessionId = $('#resultSession').val();
                var term = $('#resultTerm').val();
                var classId = $('#resultClass').val();
                var subClassId = $('#resultSubClass').val();
                var file = $('#resultExcelFile')[0].files[0];

                if (!sessionId || sessionId <= 0) { Swal.fire('Validation Error', 'Please select an academic session.', 'warning'); return; }
                if (!term || term <= 0) { Swal.fire('Validation Error', 'Please select a term.', 'warning'); return; }
                if (!classId || classId <= 0) { Swal.fire('Validation Error', 'Please select a class.', 'warning'); return; }
                if (!subClassId || subClassId <= 0) { Swal.fire('Validation Error', 'Please select a sub class.', 'warning'); return; }
                if (!file) { Swal.fire('Validation Error', 'Please select an Excel file.', 'warning'); return; }

                var formData = new FormData();
                formData.append('SessionId', sessionId);
                formData.append('Term', term);
                formData.append('SchoolClassId', classId);
                formData.append('SubClassId', subClassId);
                formData.append('ExcelFile', file);

                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i> Uploading...');

                $.ajax({
                    url: '/V1/ImportAssessmentExcel',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        btn.prop('disabled', false).html('<i class="bi bi-upload me-1"></i>Upload Assessment Sheet');
                        $('#resultExcelFile').val('');

                        if (response.success) {
                            var html = '<div class="alert alert-success mt-3"><i class="bi bi-check-circle-fill me-2"></i>' + response.message + '</div>';
                            if (response.data && response.data.errors && response.data.errors.length > 0) {
                                html += '<div class="mt-2"><p class="text-danger fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Errors:</p><ul class="small" style="max-height:200px;overflow-y:auto;">';
                                $.each(response.data.errors, function (i, err) {
                                    html += '<li class="text-danger">' + err + '</li>';
                                });
                                html += '</ul></div>';
                            }
                            $('#resultUploadSummary').html(html);
                            $('#resultUploadContainer').show();
                            Swal.fire('Success', response.message, 'success');
                        } else {
                            var errHtml = '<div class="alert alert-danger mt-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>' + response.message + '</div>';
                            if (response.data && response.data.errors && response.data.errors.length > 0) {
                                errHtml += '<div class="mt-2"><p class="text-danger fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Details:</p><ul class="small" style="max-height:200px;overflow-y:auto;">';
                                $.each(response.data.errors, function (i, err) {
                                    errHtml += '<li class="text-danger">' + err + '</li>';
                                });
                                errHtml += '</ul></div>';
                            }
                            $('#resultUploadSummary').html(errHtml);
                            $('#resultUploadContainer').show();
                            Swal.fire('Upload Failed', response.message, 'error');
                        }
                    },
                    error: function () {
                        btn.prop('disabled', false).html('<i class="bi bi-upload me-1"></i>Upload Assessment Sheet');
                        Swal.fire('Error', 'An unexpected error occurred while uploading the file.', 'error');
                    }
                });
            });
        });
    </script>
}
        <div class="mgmt-card-body">
            <table id="resultReportTable" class="table table-striped table-bordered nowrap table-sm table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th>S/N</th>
                        <th>Student Name</th>
                        <th>Admission Number</th>
                        <th>Class</th>
                        <th>Term</th>
                        <th>Session</th>
                        <th>Subjects</th>
                        <th>Attend</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ResultSheet.Any())
                    {
                        int sn = 1;
                        @foreach (var result in Model.ResultSheet)
                        {
                            <tr>
                                <td>@sn</td>
                                <td>@result.name</td>
                                <td>@result.regnumber</td>
                                <td>@result.schoolclass</td>
                                <td>@result.term</td>
                                <td>@result.session</td>
                                <td>@(result.resultStatus ? Html.Raw($"<span class='badge bg-success'>{result.subjects}</span>") : Html.Raw($"<span class='badge bg-danger'>{result.subjects}</span>"))</td>
                                <td>@(result.attendance ? Html.Raw($"<span class='badge bg-success'><i class='bi bi-check2-all'></i></span>") : Html.Raw($"<span class='badge bg-danger'><i class='bi bi-x-circle'></i></span>"))</td>
                                <td>
                                    <a href="/result-manager/edit-result/@result.termRegId" title="Edit result" class="btn btn-sm btn-outline-success"><i class="bi bi-pencil-square me-2"></i>Edit</a>
                                    <a asp-page="/result-manager/terminal-result/detail" asp-route-id="@result.termRegId" title="View terminal result" class="btn btn-sm btn-outline-info"><i class="bi bi-eye me-2"></i>View</a>
                                </td>
                            </tr>
                            sn++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<!-- Batch Excel Upload Modal -->
<div class="modal fade" id="batchExcelModal" tabindex="-1" aria-labelledby="batchExcelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header new-bg-background  text-white">
                <h5 class="modal-title" id="batchExcelModalLabel">
                    <i class="bi bi-file-earmark-excel me-2"></i>Upload Result Assessment Sheet
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Upload an Excel file downloaded from assessment sheet.
                </div>
                <form id="batchExcelForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="batchSession" class="form-label">Academic Session <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchSession" required asp-items="@Model.SelectionViewModal.AcademicSession">
                                <option value="">---Select Session---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="batchTerm" class="form-label">Term <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchTerm" required asp-items="@Model.SelectionViewModal.Terms">
                                <option value="">---Select Term---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="batchClass" class="form-label">Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchClass" required asp-items="@Model.SelectionViewModal.SchoolClasses">
                                <option value="">---Select Class---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="batchSubClass" class="form-label">Sub Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="batchSubClass" required asp-items="@Model.SelectionViewModal.SubClass">
                                <option value="">---Select Sub Class---</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="batchExcelFile" class="form-label">Excel File (.xlsx) <span class="text-danger">*</span></label>
                            <input type="file" class="form-control" id="batchExcelFile" accept=".xlsx,.xls" required />
                            <div class="form-text">The file should contain assessment sheet report.</div>
                        </div>
                    </div>
                </form>
                <!-- Results Container (hidden by default) -->
                <div id="batchResultsContainer" class="mt-3" style="display:none;">
                    <hr />
                    <h6><i class="bi bi-clipboard-data me-2"></i>Registration Results</h6>
                    <div id="batchResultsSummary"></div>
                    <div id="batchResultsErrors" class="mt-2" style="display:none;">
                        <p class="text-danger fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Failed Registrations:</p>
                        <div id="batchErrorsList" class="small" style="max-height: 200px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>Close
                </button>
                <button type="button" class="btn btn-success" id="btnSubmitBatchExcel">
                    <i class="bi bi-upload me-1"></i>Upload & Register
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Assessment Sheet Modal -->
<div class="modal fade" id="resultExcelModal" tabindex="-1" aria-labelledby="resultExcelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header new-bg-background text-white">
                <h5 class="modal-title" id="resultExcelModalLabel">
                    <i class="bi bi-file-spreadsheet me-2"></i>Assessment Sheet
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Download the assessment sheet template from the View Sheet page, fill in the scores, and upload here.
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <a asp-page="assessment" class="btn btn-outline-primary w-100">
                            <i class="bi bi-table me-1"></i> Open Assessment Sheet
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a asp-page="assessment" class="btn btn-outline-success w-100">
                            <i class="bi bi-download me-1"></i> Download Template (CSV/Excel)
                        </a>
                    </div>
                </div>
                <hr />
                <form id="resultExcelForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="resultSession" class="form-label">Academic Session <span class="text-danger">*</span></label>
                            <select class="form-select" id="resultSession" required asp-items="@Model.SelectionViewModal.AcademicSession">
                                <option value="">---Select Session---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="resultTerm" class="form-label">Term <span class="text-danger">*</span></label>
                            <select class="form-select" id="resultTerm" required asp-items="@Model.SelectionViewModal.Terms">
                                <option value="">---Select Term---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="resultClass" class="form-label">Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="resultClass" required asp-items="@Model.SelectionViewModal.SchoolClasses">
                                <option value="">---Select Class---</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="resultSubClass" class="form-label">Sub Class <span class="text-danger">*</span></label>
                            <select class="form-select" id="resultSubClass" required asp-items="@Model.SelectionViewModal.SubClass">
                                <option value="">---Select Sub Class---</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="resultExcelFile" class="form-label">Assessment Excel File (.xlsx) <span class="text-danger">*</span></label>
                            <input type="file" class="form-control" id="resultExcelFile" accept=".xlsx,.xls" required />
                            <div class="form-text">Upload the completed assessment sheet with scores filled in.</div>
                        </div>
                    </div>
                </form>
                <div id="resultUploadContainer" class="mt-3" style="display:none;">
                    <hr />
                    <h6><i class="bi bi-clipboard-data me-2"></i>Upload Results</h6>
                    <div id="resultUploadSummary"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>Close
                </button>
                <button type="button" class="btn btn-success" id="btnSubmitResultExcel">
                    <i class="bi bi-upload me-1"></i>Upload Assessment Sheet
                </button>
            </div>
        </div>
    </div>
</div>