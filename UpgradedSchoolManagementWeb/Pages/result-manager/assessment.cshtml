@page
@model UpgradedSchoolManagementWeb.Pages.result_manager.assessmentModel
@{
    ViewData["Title"] = "Assessment Sheet";
    var scoreProps = new[] { "scoreOne", "scoreTwo", "scoreThree", "scoreFour", "scoreFive", "scoreSix" };
}
@section Sheets {
    <partial name="_DataTablesSheetFiles" />
}

<div class="mgmt-page">
    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-table me-2" style="color:var(--accent)"></i>Assessment Sheet</div>
            <div class="mgmt-sub">View and manage students assessment scores</div>
        </div>
        <div>
            <a asp-page="index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Results
            </a>
        </div>
    </div>

    <div class="mgmt-card mt-3">
        <div class="mgmt-card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Session</label>
                    <select asp-for="SessionId" asp-items="@Model.SelectionView.AcademicSession" class="form-select">
                        <option value="">---Select Session---</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Term</label>
                    <select asp-for="TermValue" asp-items="@Model.SelectionView.Terms" class="form-select">
                        <option value="">---Select Term---</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Class</label>
                    <select asp-for="SchoolClassId" asp-items="@Model.SelectionView.SchoolClasses" class="form-select">
                        <option value="">---Select Class---</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Sub Class</label>
                    <select asp-for="SubClassId" asp-items="@Model.SelectionView.SubClass" class="form-select">
                        <option value="">---Select Sub Class---</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i> Load
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.HasData)
    {
        <div class="mgmt-card mt-3">
            <div class="mgmt-card-body">
                <div class="table-responsive">
                    <table id="assessmentTable" class="table table-striped table-bordered nowrap table-sm table-hover" style="width:100%">
                        <thead class="table-primary">
                            <tr>
                                <th>S/N</th>
                                <th>Student Name</th>
                                <th>Admission No</th>
                                <th>Session</th>
                                <th>Term</th>
                                <th>Class</th>
                                <th>Code</th>
                                <th>Subject</th>
                                @foreach (var cfg in Model.AssessmentConfigs)
                                {
                                    <th>
                                        @cfg.AssessmentName (@cfg.AssessmentScore)
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.AssessmentSheet)
                            {
                                var vals = new[] { row.ScoreOne, row.ScoreTwo, row.ScoreThree, row.ScoreFour, row.ScoreFive, row.ScoreSix };
                                <tr>
                                    <td>@row.Sn</td>
                                    <td>@row.StudentName</td>
                                    <td>@row.AdmissionNumber</td>
                                    <td>@Model.SessionName</td>
                                    <td>@Model.TermName</td>
                                    <td>@Model.ClassName - @Model.SubClassName</td>
                                    <td>@row.SubjectId</td>
                                    <td>@row.SubjectName</td>
                                    @for (int j = 0; j < Model.AssessmentConfigs.Count && j < 6; j++)
                                    {
                                        <td>@(vals[j].HasValue ? vals[j].Value.ToString("0.#") : "")</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (Model.SessionId > 0 || Model.TermValue > 0 || Model.SchoolClassId > 0 || Model.SubClassId > 0)
    {
        <div class="alert alert-info mt-3">
            <i class="bi bi-info-circle me-2"></i>No records found for the selected criteria.
        </div>
    }
</div>

@section Scripts {
    <partial name="_DataTablesScriptsFiles" />
    <script>
        $(function () {
            $('#assessmentTable').DataTable({
                dom: "<'row mb-2'<'col-sm-6'B><'col-sm-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row mt-2'<'col-sm-4'l><'col-sm-4 text-center'i><'col-sm-4'p>>",

                buttons: [
                    {
                        extend: 'csvHtml5',
                        text: '<i class="bi bi-filetype-csv me-1"></i> CSV',
                        className: 'btn btn-info btn-sm',
                        title: ''
                    },
                    {
                        extend: 'excelHtml5',
                        text: '<i class="bi bi-file-earmark-excel me-1"></i> Excel',
                        className: 'btn btn-success btn-sm',
                        title: ''
                    },
                    {
                        extend: 'pdfHtml5',
                        text: '<i class="bi bi-filetype-pdf me-1"></i> PDF',
                        className: 'btn btn-danger btn-sm',
                        orientation: 'landscape',
                        pageSize: 'A4',
                        title: ''
                    },
                    {
                        extend: 'print',
                        text: '<i class="bi bi-printer me-1"></i> Print',
                        className: 'btn btn-secondary btn-sm',
                        title: ''
                    }
                ],

                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                paging: false,
                ordering: true,
                info: false,
                searching: false,
                order: [[0, 'asc']],

                language: {
                    emptyTable: "No attendance records found.",
                    zeroRecords: "No matching records found.",
                    info: "Showing _START_ to _END_ of _TOTAL_ students",
                    infoEmpty: "No students available",
                    search: "Search:"
                }
            });
        
        });
    </script>
}
