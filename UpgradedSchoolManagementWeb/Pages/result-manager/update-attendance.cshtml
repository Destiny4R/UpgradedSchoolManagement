@page
@model UpgradedSchoolManagementWeb.Pages.result_manager.update_attendanceModel
@{
    ViewData["Title"] = "Update Attendance"; 
}
<div class="mgmt-page">
    <div class="mgmt-header fade-in">
        <div>
            <div class="mgmt-title"><i class="bi bi-pencil-square me-2" style="color:var(--accent)"></i>Update Attendance</div>
            <div class="mgmt-sub">Enter attendance details for each student</div>
        </div>
        <div>
            <a asp-page="index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="mgmt-card mt-3">
        <div class="mgmt-card-body">
            @if (Model.attendances.Any())
            {
                <form method="post">
                    <table class="table table-bordered table-sm table-hover table-striped">
                        <thead>
                            <tr>
                                <th>S/N</th>
                                <th>Student Name</th>
                                <th>Admission No</th>
                                <th>Term</th>
                                <th>Session</th>
                                <th>Class</th>
                                <th>Over all Attendance</th>
                                <th>Student Attendance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.attendances.Count; i++)
                            {
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@Model.attendances[i].FullName</td>
                                    <td>@Model.attendances[i].RegNumber</td>
                                    <td>@Model.attendances[i].Term</td>
                                    <td>@Model.attendances[i].Session</td>
                                    <td>@Model.attendances[i].SchoolClass</td>
                                    <td>@Model.ToTalAttendance</td>
                                    <td>
                                        <input max="@Model.ToTalAttendance" min="1" class="form-control" asp-for="@Model.attendances[i].StudentAttendance" />
                                        <input type="hidden" asp-for="@Model.attendances[i].Id" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                
                    <div class="mt-3">
                        <button type="submit" class="btn btn-success">Update Attendance</button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}