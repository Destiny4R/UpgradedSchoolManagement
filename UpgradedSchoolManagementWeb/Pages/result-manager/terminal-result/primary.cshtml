@page "{id:long}"
@model UpgradedSchoolManagementWeb.Pages.result_manager.terminal_result.primaryModel
@using UpgradedSchoolManagementModels.DTOs
@inject ApplicationDbContext _db
@{
    Layout = null;
    var result = Model.Result;
    var initial = string.IsNullOrWhiteSpace(result.StudentName) ? "P" : result.StudentName.Substring(0, 1);
    var adminUser = _db.Appsettings.Where(a => a.IsAdmin).OrderByDescending(a => a.UpdatedDate).FirstOrDefault();
    string PrincipalSignaturePath = string.Empty;
    if(adminUser != null)
    {
        PrincipalSignaturePath = adminUser.PrincipalSignature ?? string.Empty;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Primary Terminal Result</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-family: Inter, Arial, sans-serif; background: #f7f8fc; color: #1a202c; font-size: 0.9rem; }
        .result-shell { max-width: 1180px; margin: 0 auto; background: #fff; }
        .header-band { background: #1a5276; color: #fff; }
        .gold-stripe { height: 6px; background: linear-gradient(90deg, #f6d365, #fda085); }
        .section-head { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #1a5276; }
        .card-clean { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; }
        .tbl-result th { background: #eaf0fb; color: #1a5276; font-weight: 600; font-size: 0.78rem; border-bottom: 2px solid #1a5276; }
        .tbl-result td { border-color: #f0f4f8; vertical-align: middle; font-size: 0.84rem; }
        .tbl-result tfoot td { background: #f0f4f8; font-weight: 700; }
        .grade-pill { display: inline-block; min-width: 28px; padding: 2px 8px; border-radius: 999px; font-weight: 700; font-size: 0.8rem; text-align: center; }
        .gA { background: #d1fae5; color: #065f46; }
        .gB { background: #dbeafe; color: #1e40af; }
        .gC { background: #fef3c7; color: #92400e; }
        .gD { background: #ffe4e6; color: #9f1239; }
        .gF { background: #fee2e2; color: #991b1b; }
        .info-label { font-size: 0.72rem; color: #718096; font-weight: 700; text-transform: uppercase; }
        .info-value { font-weight: 600; }
        .rotate-upward { transform: rotate(180deg); writing-mode: vertical-lr; }
        .sig-line { border-top: 1.5px solid #333; width: 140px; }
        .sig-name { font-style: italic; font-size: 1.1rem; }
        .print-actions { position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); border-bottom: 1px solid #e2e8f0; padding: 10px 0; }
        @@media print { body { background: #fff; } .print-actions { display: none !important; } .result-shell { max-width: 100%; } }
    </style>
</head>
<body>
    @if (!result.IsAllowed)
    {
        <div class="container py-5">
            <div class="card-clean p-4">
                <h4 class="text-danger mb-3">Result Access Restricted</h4>
                <p>@result.AccessMessage</p>
                <table class="table table-sm">
                    <thead><tr><th>Compulsory Payment Item</th><th class="text-end">Expected</th><th class="text-end">Paid</th><th class="text-end">Outstanding</th></tr></thead>
                    <tbody>
                        @foreach (var item in result.OutstandingPayments)
                        {
                            <tr>
                                <td>@item.PaymentItemName</td>
                                <td class="text-end">₦@item.ExpectedAmount.ToString("0.00")</td>
                                <td class="text-end">₦@item.AmountPaid.ToString("0.00")</td>
                                <td class="text-end">₦@item.Balance.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><td colspan="3" class="text-end fw-bold">Total Outstanding</td><td class="text-end fw-bold">₦@result.TotalOutstanding.ToString("0.00")</td></tr>
                    </tfoot>
                </table>
                <p class="text-danger fw-bold">Please complete the compulsory payment before viewing or printing this result.</p>
            </div>
        </div>
    }
    else
    {
        <div class="print-actions no-print">
            <div class="container">
                <button class="btn btn-primary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print Result</button>
            </div>
        </div>

        <div class="container py-3" style="max-width: 100%;">
            <div class="result-shell">
                <div class="gold-stripe mb-0 rounded-top"></div>
                <div class="header-band px-4 py-4 text-center">
                    <div class="row align-items-center">
                        <div class="col-2 d-flex justify-content-center">
                            @if (!string.IsNullOrEmpty(result.SchoolLogoUrl))
                            {
                                <img src="@result.SchoolLogoUrl" alt="Logo" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:3px solid #1a5276;" />
                            }
                        </div>
                        <div class="col-8">
                            <div class="mb-0 fw-bold" style="font-size:1.05rem;letter-spacing:0.03em;">@result.SchoolName</div>
                            <h4 class="mb-0 fw-bold" style="letter-spacing: 0.04em;">PRIMARY SCHOOL TERMINAL REPORT</h4>
                            <p class="mb-0 opacity-75" style="font-size: 0.82rem;">Academic Session @result.Session &mdash; @result.Term</p>
                            <span class="badge mt-2 px-4 py-2" style="background: rgba(246,211,101,0.25); border: 1px solid #f6d365; font-size: 0.88rem;">PRIMARY TERMINAL RESULT</span>
                        </div>
                        <div class="col-2 d-flex justify-content-center">
                            @if (!string.IsNullOrEmpty(result.PicturePath))
                            {
                                <img src="@result.PicturePath" alt="Student" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:3px solid #f6d365;" />
                            }
                            else
                            {
                                <div style="width:64px;height:64px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;border:3px solid #f6d365;color:#1a5276;font-weight:800;">@initial</div>
                            }
                        </div>
                    </div>
                </div>
                <div class="gold-stripe mb-4"></div>

                <div class="card-clean p-3 mb-3">
                    <div class="row g-2">
                        <div class="col-sm-5"><div class="info-label">Full Name</div><div class="info-value text-uppercase">@result.StudentName</div></div>
                        <div class="col-sm-2"><div class="info-label">Adm. No.</div><div class="info-value">@result.AdmissionNumber</div></div>
                        <div class="col-sm-2"><div class="info-label">Class</div><div class="info-value">@result.ClassName</div></div>
                        <div class="col-sm-1"><div class="info-label">Age</div><div class="info-value">@result.Age</div></div>
                        <div class="col-sm-2"><div class="info-label">Term</div><div class="info-value">@result.Term</div></div>
                    </div>
                    <hr class="my-2" />
                    <div class="row g-2">
                        <div class="col-sm-2"><div class="info-label">Days Present</div><div class="info-value">@result.DaysPresent / @result.Attendance</div></div>
                        <div class="col-sm-2"><div class="info-label">Days Absent</div><div class="info-value">@result.DaysAbsent</div></div>
                        <div class="col-sm-2"><div class="info-label">No. in Class</div><div class="info-value">@result.ClassSize</div></div>
                        <div class="col-sm-2"><div class="info-label">Position</div><div class="info-value">@result.ClassPosition</div></div>
                        <div class="col-sm-2"><div class="info-label">Total Scores</div><div class="info-value">@(result.AcademicRows.Count()*100)</div></div>
                        <div class="col-sm-2"><div class="info-label">Average</div><div class="info-value">@result.AcademicAverage.ToString("0.##")%</div></div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-8">
                        <div class="card-clean mb-3">
                            <div class="p-0 px-3 pt-3">
                                <div class="section-head mb-2 ps-1">Academic Performance</div>
                                <div class="table-responsive1">
                                    <table class="table table-sm tbl-result mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width:24%">Subject</th>
                                                @{ var headerAssessments = result.AcademicRows.FirstOrDefault()?.Assessments ?? new List<ResultTableAssessmentDto>(); }
                                                @foreach (var assessment in headerAssessments)
                                                {
                                                    <th class="text-center rotate-upward">@assessment.AssessmentName (@assessment.AssessmentScore.ToString("0.#"))</th>
                                                }
                                                <th class="text-center rotate-upward">Total</th>
                                                <th class="text-center rotate-upward">Lowest in Class</th>
                                                <th class="text-center rotate-upward">Highest in Class</th>
                                                <th class="text-center rotate-upward">Grade</th>
                                                <th class="text-center rotate-upward">Position in Subject</th>
                                                <th>Remark</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in result.AcademicRows)
                                            {
                                                <tr>
                                                    <td>@row.SubjectName</td>
                                                    @foreach (var assessment in row.Assessments)
                                                    {
                                                        <td class="text-center">@(assessment.StudentScore.HasValue ? assessment.StudentScore.Value.ToString("0.#") : string.Empty)</td>
                                                    }
                                                    <td class="text-center fw-bold">@row.TotalScore.ToString("0.#")</td>
                                                    <td class="text-center">@row.LowestScore.ToString("0.#")</td>
                                                    <td class="text-center">@row.HighestScore.ToString("0.#")</td>
                                                    <td class="text-center"><span class="grade-pill @GetGradeClass(row.Grade)">@row.Grade</span></td>
                                                    <td class="text-center fw-600">@row.SubjectPosition</td>
                                                    <td>@row.Remark</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    <div class="row mt-1">
                                        <div class="col-4 text-center"><strong>Total &amp; Average</strong></div>
                                        <div class="col-4 text-center"><span class="total-score">@result.AcademicTotal.ToString("0.#")</span> &amp; <small>@result.AcademicAverage.ToString("0.##")%</small></div>
                                        <div class="col-4 text-center"><span class="grade-pill @GetGradeClass(result.OverallRemark)">@result.OverallRemark</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card-clean p-3 mb-2">
                            <div class="section-head mb-2">Affective Domain</div>
                            @if (!result.AffectiveSkills.Any()) { <p class="text-muted small mb-0">No affective skills assigned.</p> }
                            else { foreach (var skill in result.AffectiveSkills) { <div class="d-flex justify-content-between small"><span>@skill.SkillName</span><span class="grade-pill @GetScoreClass(skill.Score)">@skill.Score - @skill.ScoreLabel</span></div> } }
                        </div>
                        <div class="card-clean p-3">
                            <div class="section-head mb-2">Psychomotor Skills</div>
                            @if (!result.PsychomotorSkills.Any()) { <p class="text-muted small mb-0">No psychomotor skills assigned.</p> }
                            else { foreach (var skill in result.PsychomotorSkills) { <div class="d-flex justify-content-between small"><span>@skill.SkillName</span><span class="grade-pill @GetScoreClass(skill.Score)">@skill.Score - @skill.ScoreLabel</span></div> } }
                        </div>
                    </div>
                </div>

                <div class="card-clean p-3 mb-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="section-head mb-1">Class Teacher's Remark</div>
                            <p class="mb-2" style="font-size:0.87rem;background:#f0fdf4;padding:10px 14px;border-left:4px solid #22c55e;border-radius:0 8px 8px 0;">@result.ClassTeacherRemark</p>
                            <div class="sig-name mb-1">@result.ClassTeacherName</div>
                            <div class="sig-line"></div>
                            <div style="font-size:0.75rem;color:#666;">Class Teacher &mdash; @result.ClassName</div>
                        </div>
                        <div class="col-md-6">
                            <div class="section-head mb-1">Principal's Remark</div>
                            <p class="mb-2" style="font-size:0.87rem;background:#eff6ff;padding:10px 14px;border-left:4px solid #3b82f6;border-radius:0 8px 8px 0;">@result.PrincipalRemark</p>
                            <div class="row">
                                <div class="col-8">
                                    <div class="sig-name mb-1">@result.PrincipalName</div>
                                    <div class="sig-line"></div>
                                    <div style="font-size:0.75rem;color:#666;">Principal</div>
                                </div>
                                <div class="col-4">
                                    <img src="@(PrincipalSignaturePath)" width="90px" height="60px" alt="Principal Signature" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-clean p-3 mb-3">
                    <div class="row g-2 text-center">
                        <div class="col-sm-4"><div class="info-label">Next Term Begins</div><div class="info-value">@result.NextTermStart</div></div>
                        <div class="col-sm-4"><div class="info-label">School Fees</div><div class="info-value">₦@result.NextTermFees</div></div>
                        <div class="col-sm-4"><div class="info-label">Parent's Signature</div><div style="border-bottom:1.5px solid #999;height:28px;margin-top:4px;"></div></div>
                    </div>
                </div>

                <div class="">
                    <div class="desieze3"><text>KEY TO GRADING</text>&nbsp; Final Assessment(A - Distinction; B - Very Good; C - Good; D - Fair; E - Poor;)</div>
                    <div class="d-flex justify-content-between">
                        <div class="desieze3">75 and above = A; 65 - 74 = B; 55 - 64 = C; 40 - 54 = D; 39 and below = E;</div>
                        <div class="h6"><text style="font:italic;">By: D-Best Return Tech - </text><a class="text-decoration-none" href="tel:08039410863">08039410863</a></div>
                    </div>
                </div>

                <p class="text-center text-muted" style="font-size:0.72rem;">This report is computer-generated. Alteration is a punishable offence.</p>
            </div>
        </div>
    }
</body>
</html>

@functions {
    string GetGradeClass(string grade)
    {
        return grade switch
        {
            "A" or "Distinction" => "gA",
            "B" or "Very Good" => "gB",
            "C" or "Good" => "gC",
            "D" or "Fair" => "gD",
            _ => "gF"
        };
    }

    string GetScoreClass(byte score)
    {
        return score switch
        {
            5 => "gA",
            4 => "gB",
            3 => "gC",
            2 => "gD",
            _ => "gF"
        };
    }
}
