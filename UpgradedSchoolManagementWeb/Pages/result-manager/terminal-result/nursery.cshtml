@page "{id:long}"
@model UpgradedSchoolManagementWeb.Pages.result_manager.terminal_result.nurseryModel
@using UpgradedSchoolManagementModels.DTOs
@{
    Layout = null;
    var result = Model.Result;
    var initial = string.IsNullOrWhiteSpace(result.StudentName) ? "N" : result.StudentName.Substring(0, 1);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nursery Terminal Result</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-family: Nunito, Arial, sans-serif; background: #f0f8ff; color: #2d3748; font-size: 0.9rem; }
        .result-shell { max-width: 1180px; margin: 0 auto; background: #fff; }
        .school-header { background: linear-gradient(135deg, #6c63ff 0%, #3b82f6 100%); color: #fff; border-radius: 0 0 2rem 2rem; }
        .school-crest { width: 80px; height: 80px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; border: 4px solid #ffd700; color: #6c63ff; font-weight: 800; }
        .result-card { border-radius: 1.25rem; border: 1px solid #e2e8f0; }
        .subject-row td { vertical-align: middle; }
        .grade-badge { display: inline-block; width: 34px; height: 34px; border-radius: 50%; font-weight: 800; font-size: 0.95rem; line-height: 34px; text-align: center; }
        .grade-A { background: #d1fae5; color: #065f46; }
        .grade-B { background: #dbeafe; color: #1e40af; }
        .grade-C { background: #fef3c7; color: #92400e; }
        .grade-D { background: #fee2e2; color: #991b1b; }
        .section-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #6c63ff; }
        .remark-box { background: #f0fdf4; border-left: 4px solid #22c55e; border-radius: 0 0.75rem 0.75rem 0; padding: 12px; }
        .skill-row { display: flex; justify-content: space-between; font-size: 0.86rem; margin-bottom: 8px; }
        .skill-score { font-weight: 800; }
        .print-actions { position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); border-bottom: 1px solid #e2e8f0; padding: 10px 0; }
        @@media print { body { background: #fff; } .print-actions { display: none !important; } .result-shell { max-width: 100%; } }
    </style>
</head>
<body>
    @if (!result.IsAllowed)
    {
        <div class="container py-5">
            <div class="result-card card p-4">
                <h4 class="text-danger mb-3">Result Access Restricted</h4>
                <p>@result.AccessMessage</p>
                <ul>
                    @foreach (var item in result.OutstandingPayments)
                    {
                        <li>@item.PaymentItemName &mdash; outstanding balance: ₦@item.Balance.ToString("0.00")</li>
                    }
                </ul>
                <p class="text-danger fw-bold">Total outstanding: ₦@result.TotalOutstanding.ToString("0.00"). Please complete payment before viewing or printing this result.</p>
            </div>
        </div>
    }
    else
    {
        <div class="print-actions no-print">
            <div class="container"><button class="btn btn-primary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print Result</button></div>
        </div>

        <div class="container py-3" style="max-width:100%;">
            <div class="result-shell">
                <div class="school-header p-4">
                    <div class="row align-items-center">
                        <div class="col-2 d-flex justify-content-center">
                            @if (!string.IsNullOrEmpty(result.SchoolLogoUrl))
                            {
                                <img src="@result.SchoolLogoUrl" alt="Logo" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:4px solid #ffd700;" />
                            }
                            else
                            {
                                <div class="school-crest">N</div>
                            }
                        </div>
                        <div class="col-8 text-center">
                            <div class="fw-700 mb-0" style="font-size:1.1rem;letter-spacing:0.02em;">@result.SchoolName</div>
                            <h3 class="fw-800 mb-0" style="letter-spacing:0.03em;">NURSERY SCHOOL TERMINAL REPORT</h3>
                            <p class="mb-1 opacity-75" style="font-size:0.85rem;">Academic Session @result.Session &mdash; @result.Term</p>
                            <span class="badge rounded-pill px-4 py-2 mt-1 bg-info" style="font-size:0.9rem; font-weight:700;">TERMINAL REPORT CARD</span>
                        </div>
                        <div class="col-2"></div>
                    </div>
                </div>

                <div class="result-card card mb-4 px-4 py-3">
                    <div class="row text-center g-2">
                        <div class="col-4"><div class="section-label">Academic Session</div><div class="fw-700">@result.Session</div></div>
                        <div class="col-4"><div class="section-label">Term</div><div class="fw-700">@result.Term</div></div>
                        <div class="col-4"><div class="section-label">Class</div><div class="fw-700">@result.ClassName</div></div>
                    </div>
                </div>

                <div class="result-card card mb-4 px-4 py-3">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            @if (!string.IsNullOrEmpty(result.PicturePath))
                            {
                                <img src="@result.PicturePath" alt="Student" style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:4px solid #ffd700;" />
                            }
                            else
                            {
                                <div class="school-crest" style="width:60px;height:60px;font-size:1.7rem;border-width:3px;">@initial</div>
                            }
                        </div>
                        <div class="col">
                            <div class="row g-2">
                                <div class="col-sm-6"><div class="section-label">Pupil's Name</div><div class="fw-700 text-uppercase">@result.StudentName</div></div>
                                <div class="col-sm-3"><div class="section-label">Admission No.</div><div class="fw-700">@result.AdmissionNumber</div></div>
                                <div class="col-sm-3"><div class="section-label">Age</div><div class="fw-700">@result.Age</div></div>
                                <div class="col-sm-4"><div class="section-label">Days Present</div><div class="fw-700">@result.DaysPresent of @result.Attendance</div></div>
                                <div class="col-sm-4"><div class="section-label">Times Late</div><div class="fw-700">@result.TimesLate</div></div>
                                <div class="col-sm-4"><div class="section-label">Average</div><div class="fw-700">@result.AcademicAverage.ToString("0.##")%</div></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-8">
                        <div class="result-card card mb-4">
                            <div class="card-body px-4">
                                <h6 class="section-label mb-3">Academic Performance</h6>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0" style="font-size:0.9rem;">
                                        <thead style="background:#f5f3ff;">
                                            <tr>
                                                <th class="py-2">Subject</th>
                                                @{ var headerAssessments = result.AcademicRows.FirstOrDefault()?.Assessments ?? new List<ResultTableAssessmentDto>(); }
                                                @foreach (var assessment in headerAssessments)
                                                {
                                                    <th class="text-center">@assessment.AssessmentName (@assessment.AssessmentScore.ToString("0.#"))</th>
                                                }
                                                <th class="text-center">Total</th>
                                                <th class="text-center rotate-upward">Lowest in Class</th>
                                                <th class="text-center rotate-upward">Highest in Class</th>
                                                <th class="text-center">Grade</th>
                                                <th class="text-center">Position in Subject</th>
                                                <th>Remark</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in result.AcademicRows)
                                            {
                                                <tr class="subject-row">
                                                    <td>@row.SubjectName</td>
                                                    @foreach (var assessment in row.Assessments)
                                                    {
                                                        <td class="text-center">@(assessment.StudentScore.HasValue ? assessment.StudentScore.Value.ToString("0.#") : string.Empty)</td>
                                                    }
                                                    <td class="text-center fw-700">@row.TotalScore.ToString("0.#")</td>
                                                    <td class="text-center">@row.LowestScore.ToString("0.#")</td>
                                                    <td class="text-center">@row.HighestScore.ToString("0.#")</td>
                                                    <td class="text-center"><span class="grade-badge @GetGradeClass(row.Grade)">@row.Grade</span></td>
                                                    <td class="text-center fw-600">@row.SubjectPosition</td>
                                                    <td>@row.Remark</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot style="background:#f5f3ff;">
                                            <tr>
                                                <td colspan="@Math.Max(3, headerAssessments.Count + 1)" class="fw-700">Total / Average</td>
                                                <td class="text-center fw-800">@result.AcademicTotal.ToString("0.#") / @result.AcademicAverage.ToString("0.##")%</td>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="result-card card px-4 py-3">
                            <h6 class="section-label mb-3">Psychomotor &amp; Affective Skills</h6>
                            @foreach (var skill in result.PsychomotorSkills.Concat(result.AffectiveSkills))
                            {
                                <div class="skill-row">
                                    <span>@skill.SkillName (@skill.DomainName)</span>
                                    <span class="skill-score">@skill.Score/5 - @skill.ScoreLabel</span>
                                </div>
                            }
                        </div>
                        <div class="result-card card px-4 py-3 mt-3">
                            <h6 class="section-label mb-2">Grading Key</h6>
                            <table class="table table-sm mb-0" style="font-size:0.85rem;">
                                <tbody>
                                    <tr><td><span class="grade-badge grade-A">A</span></td><td>75 – 100</td><td class="fw-600 text-success">Excellent</td></tr>
                                    <tr><td><span class="grade-badge grade-B">B</span></td><td>65 – 74</td><td class="fw-600 text-primary">Very Good</td></tr>
                                    <tr><td><span class="grade-badge grade-C">C</span></td><td>50 – 64</td><td class="fw-600 text-warning">Good</td></tr>
                                    <tr><td><span class="grade-badge grade-D">D</span></td><td>40 – 49</td><td class="fw-600 text-danger">Fair</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="result-card card mb-4 px-4 py-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="section-label mb-1">Class Teacher's Remark</div>
                            <div class="remark-box">@result.ClassTeacherRemark</div>
                            <div class="mt-2 d-flex align-items-center gap-2"><div style="font-size:0.82rem;color:#888;">Signature:</div><div class="fw-700">@result.ClassTeacherName</div></div>
                        </div>
                        <div class="col-md-6">
                            <div class="section-label mb-1">Head Teacher's Remark</div>
                            <div class="remark-box">@result.PrincipalRemark</div>
                            <div class="mt-2 d-flex align-items-center gap-2"><div style="font-size:0.82rem;color:#888;">Signature:</div><div class="fw-700">@result.PrincipalName</div></div>
                        </div>
                    </div>
                </div>

                <div class="result-card card mb-4 px-4 py-3">
                    <div class="row g-2 text-center">
                        <div class="col-sm-4"><div class="section-label">Next Term Begins</div><div class="fw-700">@result.NextTermStart</div></div>
                        <div class="col-sm-4"><div class="section-label">School Fees</div><div class="fw-700">₦@result.NextTermFees</div></div>
                        <div class="col-sm-4"><div class="section-label">Promoted To</div><div class="fw-700 text-success">@result.NextClass</div></div>
                    </div>
                </div>

                <p class="text-center text-muted" style="font-size:0.75rem;">This result is computer-generated and valid without a stamp.</p>
            </div>
        </div>
    }
</body>
</html>

@functions {
    string GetGradeClass(string grade)
    {
        return grade switch
        {
            "A" or "Distinction" => "grade-A",
            "B" or "Very Good" => "grade-B",
            "C" or "Good" => "grade-C",
            "D" or "Fair" => "grade-D",
            _ => "grade-D"
        };
    }
}
